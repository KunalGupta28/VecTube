# ==============================================================================
# Master .gitignore for VecTube Project
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environment Variables & Secrets
# ------------------------------------------------------------------------------
.env
.env.*
!.env.sample
!.env.example

# ------------------------------------------------------------------------------
# 2. Local Databases & Vector Stores
# ------------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*-journal
chroma_db/
chroma_data/
vectube.db

# ------------------------------------------------------------------------------
# 3. Dependencies & Virtual Environments
# ------------------------------------------------------------------------------
node_modules/
.venv/
venv/
env/
__pycache__/
*.pyc

# ------------------------------------------------------------------------------
# 4. Build Outputs & Cache Directories
# ------------------------------------------------------------------------------
dist/
build/
.nuxt/
.output/
.cache/
.vite/
.pytest_cache/

# ------------------------------------------------------------------------------
# 5. OS & IDE Specific Files
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log

# ------------------------------------------------------------------------------
# 6. Specific Sub-project Exclusions
# ------------------------------------------------------------------------------
VecTube/engine/.env
VecTube/web/.env
